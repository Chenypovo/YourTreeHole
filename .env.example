# LLM 配置 — 支持所有 OpenAI Compatible API
# 复制此文件为 .env 并填入你的 key

# API Base URL（按你的服务商修改）
# 也可以把非敏感的 base_url / model 写在 config/settings.toml
# OpenAI:      https://api.openai.com/v1
# DeepSeek:    https://api.deepseek.com/v1
# ZAI:         https://api.z.ai/api/coding/paas/v4
# Groq:        https://api.groq.com/openai/v1
# 本地 Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API Key
OPENAI_API_KEY=your-api-key-here

# 模型名称（按你的服务商修改）
# gpt-4.1-mini / gpt-4o / deepseek-chat / glm-4.7 / llama3 等
OPENAI_MODEL=gpt-4.1-mini

# Telegram bot（可选）
# 从 BotFather 获取 token；用户白名单写在 config/settings.toml 的 [telegram].allowed_user_ids。
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
